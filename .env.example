# Required — the app shows a "not configured" screen until both are set.
VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=your-storefront-api-public-token
VITE_SHOPIFY_API_VERSION=2025-01

# Optional
VITE_SHOPIFY_FEATURED_COLLECTIONS=
VITE_SHOPIFY_PRODUCTS_PER_PAGE=24
VITE_SHOPIFY_ARTICLES_PER_PAGE=10
VITE_SHOPIFY_DEFAULT_BLOG_HANDLE=news
